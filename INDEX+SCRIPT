function gerarJWT(user) {
  const payload = {id:user.id,nome:user.nome,perfil:user.perfil,iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+7200};
  return jwt_js.sign(payload, JWT_SECRET);
}
function validarJWT(token) { 
  try { 
    jwt_js.verify(token, JWT_SECRET); 
    return true; 
  } catch(e) { 
    return false; 
  }
}
