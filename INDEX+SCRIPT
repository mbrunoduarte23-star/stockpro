          </div>
        </div>
        <div class="card">
          <h3>💼 Caixa Diário</h3>
          <div style="font-size:18px">
            <div>Entradas: <strong>${fmtMoeda(DB.caixa.entradas)}</strong></div>
            <div>Saídas: <strong>${fmtMoeda(DB.caixa.saidas)}</strong></div>
            <div>Saldo: <strong style="color:#10b981;font-size:24px">${fmtMoeda(DB.caixa.entradas-DB.caixa.saidas)}</strong></div>
          </div>
        </div>
      </div>
    `,
    catalogo: `
      <header>
        <div class="logo">📋 Catálogo Completo</div>
        <button class="btn-nav" onclick="estado.tela='dashboard';render()">← Dashboard</button>
      </header>
      <div class="card" style="max-width:1200px">
