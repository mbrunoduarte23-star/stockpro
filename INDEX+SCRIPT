// ===== VENDAS =====
function adicionarCarrinho(codigo) {
  const prod = DB.produtos.find(p => p.codigo === codigo);
  if (!prod) return showToast('Produto não encontrado', 'error');
  if (prod.estoqueAtual <= 0) return showToast('❌ Sem estoque!', 'error');

  const item = estado.carrinho.find(i => i.codigo === codigo);
  if (item) {
    item.qtd++;
  } else {
    estado.carrinho.push({...prod, qtd: 1});
  }
  estado.tela = 'vendas';
  render();
  showToast(`✅ ${prod.nome} adicionado ao carrinho!`);
  adicionarLog('ITEM_CARRINHO', {codigo, nome: prod.nome});
}

function finalizarVenda() {
  if (!estado.carrinho.length) return showToast('Carrinho vazio', 'error');

  const total = estado.carrinho.reduce((s,i) => s + i.qtd * i.precoVenda, 0);
  const desconto = parseInt(document.getElementById('desconto-venda')?.value || 0);
  const limite = usuarioLogado?.limiteDesconto || 0;

  if (desconto > limite) return showToast(`❌ Máximo ${limite}% de desconto`, 'error');

  const valorFinal = total * (1 - desconto / 100);
  const venda = {
    id: Date.now(),
    data: new Date().toISOString(),
    usuario: usuarioLogado.nome,
    itens: [...estado.carrinho],
    totalOriginal: total,
    desconto,
    totalFinal: valorFinal,
    formaPagamento: 'Dinheiro'
  };

  // Baixar estoque
  estado.carrinho.forEach(item => {
    const prod = DB.produtos.find(p => p.codigo === item.codigo);
    if (prod) prod.estoqueAtual -= item.qtd;
  });

  DB.vendas.push(venda);
  DB.caixa.entradas += valorFinal;

  salvar();
  estado.carrinho = [];
  estado.tela = 'dashboard';
  render();

  adicionarLog('VENDA_FINALIZADA', {total: valorFinal, itens: venda.itens.length});
  showToast(`✅ Venda #${venda.id} concluída! ${fmtMoeda(valorFinal)}`);
}

// ===== MOVIMENTAÇÃO ESTOQUE =====
function movEstoque(codigo) {
  const prod = DB.produtos.find(p => p.codigo === codigo);
  if (!prod) return;

  document.getElementById('modal-produto').innerHTML = `
    <div class="modal-box">
      <h3>📦 Movimentação: ${prod.nome}</h3>
      <p>Estoque atual: <strong>${prod.estoqueAtual}</strong> un</p>
      <div class="input-group">
        <label>Tipo</label>
        <select id="mov-tipo">
          <option value="entrada">➕ Entrada</option>
          <option value="saida">➖ Saída</option>
        </select>
      </div>
      <div class="input-group">
        <label>Quantidade</label>
        <input id="mov-qtd" type="number" min="1" value="1">
      </div>
      <div class="input-group">
        <label>Motivo (opcional)</label>
        <input id="mov-motivo" placeholder="Ex: Compra fornecedor">
      </div>
      <div style="display:flex;gap:10px">
        <button class="btn-primary" style="flex:1" onclick="execMovEstoque('${codigo}')">Confirmar</button>
        <button class="btn-secondary" style="flex:1" onclick="document.getElementById('modal-produto').style.display='none'">Cancelar</button>
      </div>
    </div>`;
  document.getElementById('modal-produto').style.display = 'flex';
}

function execMovEstoque(codigo) {
  const tipo = document.getElementById('mov-tipo').value;
  const qtd = parseInt(document.getElementById('mov-qtd').value);
  const motivo = document.getElementById('mov-motivo').value;

  const prod = DB.produtos.find(p => p.codigo === codigo);
  if (!prod || qtd <= 0) return showToast('Erro na movimentação', 'error');

  if (tipo === 'saida' && prod.estoqueAtual < qtd) {
    return showToast('Estoque insuficiente!', 'error');
  }

  prod.estoqueAtual += tipo === 'entrada' ? qtd : -qtd;

  DB.logs.push({
    id: Date.now(),
    timestamp: new Date().toISOString(),
    tipo: 'ESTOQUE',
    produto: prod.nome,
    codigo,
    movimento: tipo,
    quantidade: qtd,
    motivo: motivo || 'Sem motivo',
    usuario: usuarioLogado?.nome || 'Sistema'
  });

  salvar();
  document.getElementById('modal-produto').style.display = 'none';
  render();
  showToast(`✅ ${tipo.toUpperCase()}: ${qtd}un | Novo estoque: ${prod.estoqueAtual}`);
}

// ===== EXPORT =====
function exportPDF() {
  if (!verificarSessao()) return alert('Sessão expirada!');

  const content = document.getElementById('app').cloneNode(true);
  content.querySelector('#modal-login').remove();

  const opt = {
    margin: 0.5,
    filename: `StockPro-Bearon-${new Date().toISOString().split('T')[0]}.pdf`,
    image: { type: 'jpeg', quality: 0.98 },
    html2canvas: { scale: 2, useCORS: true },
    jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
  };

  html2pdf().set(opt).from(content).save();
  showToast('📄 PDF exportado com sucesso!');
  adicionarLog('EXPORT_PDF');
}

function exportExcel() {
  if (!verificarSessao()) return alert('Sessão expirada!');

  const produtos = DB.produtos.map(p => ({
    Codigo: p.codigo,
    Produto: p.nome,
    Marca: p.marca,
    EstoqueAtual: p.estoqueAtual,
    EstoqueMinimo: p.estoqueMin,
    PrecoVenda: fmtMoeda(p.precoVenda),
    PrecoCusto: fmtMoeda(p.precoCusto),
    Categoria: p.categoria
  }));

  const ws = XLSX.utils.json_to_sheet(produtos);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Estoque Bearon');

  XLSX.writeFile(wb, `StockPro-Bearon-Estoque-${new Date().toISOString().split('T')[0]}.xlsx`);
  showToast('📊 Excel exportado!');
  adicionarLog('EXPORT_EXCEL');
}

// ===== LOGOUT =====
function logout() {
  sessionStorage.clear();
  usuarioLogado = null;
  estado = {tela: 'login', carrinho: [], vendaAtual: {}};
  render();
  showToast('👋 Até logo!');
}

