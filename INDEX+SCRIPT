// ===== UTILITÁRIOS =====
function fmtMoeda(v) { return 'R$ ' + parseFloat(v || 0).toFixed(2).replace('.', ','); }
function showToast(msg, tipo = 'success') {
  const toast = document.createElement('div');
  toast.className = 'toast';
  toast.style.background = tipo === 'success' ? '#10b981' : '#ef4444';
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(() => toast.classList.add('show'), 100);
  setTimeout(() => toast.remove(), 4000);
}
function adicionarLog(acao, detalhes = {}) {
  if (!usuarioLogado) return;
  const log = {id: Date.now(), timestamp: new Date().toISOString(), usuario: usuarioLogado.nome, acao, detalhes};
  DB.logs.push(log);
  salvar();
  console.log('🔒 LOG:', log);
}

// ===== LOGIN =====
function fazerLogin() {
  const user = document.getElementById('login-user').value.trim();
  const pass = document.getElementById('login-pass').value;
  const usuario = DB.usuarios.find(u => u.usuario === user && u.senha === btoa(pass + 'ccb40bearon2026').slice(0,60) && u.ativo);

  if (usuario) {
    usuarioLogado = usuario;
    sessionStorage.setItem('jwt_stockpro', gerarJWT(usuario));
    estado.tela = 'dashboard';
    render();
    showToast(`👋 Bem-vindo(a), ${usuario.nome}!`);
    adicionarLog('LOGIN');
  } else {
    showToast('❌ Usuário ou senha inválidos', 'error');
  }
}

