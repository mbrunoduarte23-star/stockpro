        </div>
        <div class="card stat">
          <div class="stat-value">${fmtMoeda(DB.caixa.entradas)}</div>
          <div class="stat-label">Caixa Hoje</div>
        </div>
        <div class="card stat">
          <div class="stat-value">${DB.vendas.length}</div>
